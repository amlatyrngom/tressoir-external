#!/usr/bin/env bash

# Tressoir External MVP setup for macOS/Linux and Bash 3.2+.
# Canonical project writes are create-only. Optional root-guidance registration
# may append one contained section to selected harness instruction files.

set -u

PAYLOAD_VERSION_EXPECTED="0.1.0"
EXTENSION_ID="tressoir.tressoir-artifacts"
EXTENSION_VERSION="0.1.3"
LEGACY_EXTENSION_ID="tressoir.bridge"

CLAUDE=0
CODEX=0
PI=0
REGISTER_GUIDANCE=0
DRY_RUN=0
NO_VSCODE=0
ROOT_INPUT=""
VSCODE_BIN="code"
VSIX_INPUT=""
DEGRADED=0
VSCODE_RESOLVED=""
VSIX_PATH=""
INSTALLED_EXTENSION_VERSION=""
INSTALLED_LEGACY_EXTENSION_VERSION=""
CLAUDE_SETTINGS_TMP=""

SKILLS=(
  "tressoir-artifact-md"
  "tressoir-artifact-html"
  "tressoir-plan"
  "tressoir-working-area"
  "tressoir-canon"
  "tressoir-structured-review"
)

cleanup_claude_settings_tmp() {
  if [ -n "$CLAUDE_SETTINGS_TMP" ]; then
    rm -f "$CLAUDE_SETTINGS_TMP"
    CLAUDE_SETTINGS_TMP=""
  fi
}

# A Claude settings temp file can contain copied environment values. Remove it
# on normal exit and interruption; successful replacement clears the path.
trap cleanup_claude_settings_tmp EXIT
trap 'cleanup_claude_settings_tmp; exit 129' HUP
trap 'cleanup_claude_settings_tmp; exit 130' INT
trap 'cleanup_claude_settings_tmp; exit 143' TERM

usage() {
  cat <<'EOF'
Usage:
  tressoir-external setup [--claude] [--codex] [--pi]
      [--register-guidance]
      [--root PATH] [--vsix PATH] [--vscode-bin PATH]
      [--no-vscode] [--dry-run]

Creates a project-local IB scaffold and collision-checked harness skill links.
Installs a supplied Tressoir Artifacts VSIX into regular VS Code by default.

Root guidance registration is opt-in. With --register-guidance, setup creates
or appends a small, idempotent Tressoir section in root CLAUDE.md, root
AGENTS.md, and/or .pi/APPEND_SYSTEM.md for selected harnesses. It directly names
IB/TRESSOIR.md, IB/STATE.md, and IB/CANON/ROOT_CANON.md, upgrades only the exact
section it generated, and preserves edited, duplicated, or unrelated content.
When Claude is selected, it also writes Tressoir defaults into .claude/settings.json
(env.CLAUDE_CODE_AUTO_COMPACT_WINDOW=400000 and autoMemoryEnabled=false), merging
into any existing file with jq or python3 and preserving other settings.

Options:
  --claude           Link portable skills into .claude/skills/
  --codex            Link portable skills into .agents/skills/
  --pi               Link portable skills into .agents/skills/
  --register-guidance
                     Register IB/TRESSOIR.md, IB/STATE.md, and
                     IB/CANON/ROOT_CANON.md in selected harness prompt files
  --root PATH        Project root; defaults exactly to the current directory
  --vsix PATH        Tressoir Artifacts VSIX to install
  --vscode-bin PATH  VS Code CLI name or path; defaults to code
  --no-vscode        Do not install a VSIX
  --dry-run          Print actions without mutating the project or VS Code
  -h, --help         Show this help
EOF
}

say() {
  printf '%s\n' "$*"
}

fatal() {
  printf 'fatal: %s\n' "$*" >&2
  exit 1
}

degrade() {
  DEGRADED=1
  printf 'preserved: %s\n' "$*"
}

occupied() {
  [ -e "$1" ] || [ -L "$1" ]
}

resolve_self_dir() {
  local source_path script_dir
  source_path="$0"
  case "$source_path" in
    */*) ;;
    *)
      source_path=$(command -v "$source_path" 2>/dev/null) ||
        fatal "cannot resolve the command path"
      ;;
  esac
  script_dir=$(CDPATH= cd -- "$(dirname -- "$source_path")" 2>/dev/null && pwd -P) ||
    fatal "cannot resolve the command directory"
  printf '%s\n' "$script_dir"
}

sha256_file() {
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 "$1" | awk '{print $NF}'
  else
    fatal "payload verification needs shasum, sha256sum, or openssl"
  fi
}

validate_relative_payload_path() {
  case "$1" in
    ""|/*|../*|*/../*|*/..|*'
'*)
      return 1
      ;;
  esac
  return 0
}

verify_payload() {
  local version sums line expected relative actual listed_paths actual_paths unexpected_link
  [ -f "$PAYLOAD/VERSION" ] || fatal "missing payload VERSION"
  version=$(sed -n '1p' "$PAYLOAD/VERSION")
  [ "$version" = "$PAYLOAD_VERSION_EXPECTED" ] ||
    fatal "payload version '$version' does not match expected '$PAYLOAD_VERSION_EXPECTED'"

  sums="$PAYLOAD/SHA256SUMS"
  [ -f "$sums" ] || fatal "missing payload SHA256SUMS"

  unexpected_link=$(find "$PAYLOAD" -type l -print -quit 2>/dev/null) ||
    fatal "could not inspect the payload for symlinks"
  [ -z "$unexpected_link" ] ||
    fatal "payload must not contain symlinks: ${unexpected_link#"$PAYLOAD/"}"

  while IFS= read -r line || [ -n "$line" ]; do
    [ -n "$line" ] || continue
    expected=${line%%  *}
    relative=${line#*  }
    [ "$relative" != "$line" ] || fatal "invalid SHA256SUMS record"
    case "$expected" in
      *[!0-9a-fA-F]*|"") fatal "invalid SHA-256 digest in SHA256SUMS" ;;
    esac
    [ ${#expected} -eq 64 ] || fatal "invalid SHA-256 digest length in SHA256SUMS"
    validate_relative_payload_path "$relative" ||
      fatal "unsafe payload path in SHA256SUMS: $relative"
    [ -f "$PAYLOAD/$relative" ] ||
      fatal "payload file is missing: $relative"
    actual=$(sha256_file "$PAYLOAD/$relative")
    [ "$actual" = "$expected" ] ||
      fatal "payload checksum mismatch: $relative"
  done < "$sums"

  # Reject unlisted files and duplicate records. This matters because complete
  # skill directories are copied into projects, not just their SKILL.md files.
  listed_paths=$(awk '{ print substr($0, 67) }' "$sums" | LC_ALL=C sort)
  actual_paths=$(
    cd "$PAYLOAD" &&
      find . -type f ! -path './SHA256SUMS' -print |
      sed 's|^\./||' |
      LC_ALL=C sort
  ) || fatal "could not enumerate payload files"
  [ "$listed_paths" = "$actual_paths" ] ||
    fatal "payload file set does not exactly match SHA256SUMS"
}

validate_existing_dir_chain() {
  local rel current rest part
  rel="$1"
  current="$ROOT"
  rest="$rel"

  while [ -n "$rest" ]; do
    case "$rest" in
      */*)
        part=${rest%%/*}
        rest=${rest#*/}
        ;;
      *)
        part=$rest
        rest=""
        ;;
    esac
    current="$current/$part"
    if [ -L "$current" ]; then
      return 1
    fi
    if [ -e "$current" ] && [ ! -d "$current" ]; then
      return 1
    fi
  done
  return 0
}

preflight_project() {
  local rel skill VSIX_CANDIDATE VSIX_DIR
  [ -d "$ROOT" ] || fatal "project root is not a directory: $ROOT"
  [ ! -L "$ROOT" ] || fatal "resolved project root must not be a symlink"

  for rel in IB IB/ARTIFACTS IB/TMP IB/CANON IB/CANON/CANON_ARTIFACTS IB/skills; do
    validate_existing_dir_chain "$rel" ||
      fatal "unsafe or incompatible canonical directory path: $rel"
  done

  for skill in "${SKILLS[@]}"; do
    [ -f "$PAYLOAD/skills/$skill/SKILL.md" ] ||
      fatal "payload skill is missing SKILL.md: $skill"
  done

  [ -f "$PAYLOAD/instructions/TRESSOIR.md" ] ||
    fatal "payload is missing instructions/TRESSOIR.md"
  [ -f "$PAYLOAD/seeds/IB.gitignore" ] ||
    fatal "payload is missing seeds/IB.gitignore"
  [ -f "$PAYLOAD/seeds/TASK.md" ] || fatal "payload is missing seeds/TASK.md"
  [ -f "$PAYLOAD/seeds/STATE.md" ] || fatal "payload is missing seeds/STATE.md"
  [ -f "$PAYLOAD/seeds/ROOT_CANON.md" ] ||
    fatal "payload is missing seeds/ROOT_CANON.md"
  [ -f "$PAYLOAD/seeds/CANON_ARTIFACTS_README.md" ] ||
    fatal "payload is missing seeds/CANON_ARTIFACTS_README.md"

  if [ "$NO_VSCODE" -eq 0 ]; then
    [ -n "$VSIX_INPUT" ] ||
      fatal "VS Code installation requires --vsix PATH (or use --no-vscode)"
    case "$VSIX_INPUT" in
      /*) VSIX_CANDIDATE="$VSIX_INPUT" ;;
      *) VSIX_CANDIDATE="$PWD/$VSIX_INPUT" ;;
    esac
    [ -f "$VSIX_CANDIDATE" ] && [ ! -L "$VSIX_CANDIDATE" ] ||
      fatal "VSIX must be a regular, non-symlink file: $VSIX_INPUT"
    VSIX_DIR=$(CDPATH= cd -- "$(dirname -- "$VSIX_CANDIDATE")" 2>/dev/null && pwd -P) ||
      fatal "cannot resolve VSIX directory: $VSIX_INPUT"
    VSIX_PATH="$VSIX_DIR/$(basename -- "$VSIX_CANDIDATE")"
    case "$VSCODE_BIN" in
      */*)
        [ -x "$VSCODE_BIN" ] ||
          fatal "VS Code CLI is not executable: $VSCODE_BIN"
        VSCODE_RESOLVED="$VSCODE_BIN"
        ;;
      *)
        VSCODE_RESOLVED=$(command -v "$VSCODE_BIN" 2>/dev/null) ||
          fatal "VS Code CLI '$VSCODE_BIN' not found; use --vscode-bin or --no-vscode"
        ;;
    esac
    inspect_installed_extension ||
      fatal "failed to query extensions through: $VSCODE_RESOLVED"
  fi
}

ensure_dir() {
  local rel current rest part
  rel="$1"
  current="$ROOT"
  rest="$rel"

  while [ -n "$rest" ]; do
    case "$rest" in
      */*)
        part=${rest%%/*}
        rest=${rest#*/}
        ;;
      *)
        part=$rest
        rest=""
        ;;
    esac
    current="$current/$part"

    if [ -L "$current" ]; then
      degrade "$rel (refusing to traverse symlink: ${current#"$ROOT/"})"
      return 1
    fi
    if [ -e "$current" ]; then
      if [ ! -d "$current" ]; then
        degrade "$rel (expected a directory at ${current#"$ROOT/"})"
        return 1
      fi
      continue
    fi

    if [ "$DRY_RUN" -eq 1 ]; then
      say "would create directory: ${current#"$ROOT/"}"
    else
      if mkdir "$current" 2>/dev/null; then
        say "created directory: ${current#"$ROOT/"}"
      elif [ -d "$current" ] && [ ! -L "$current" ]; then
        :
      else
        fatal "failed to create directory: ${current#"$ROOT/"}"
      fi
    fi
  done
  return 0
}

copy_file_if_absent() {
  local source relative destination label
  source="$1"
  relative="$2"
  label="$3"
  destination="$ROOT/$relative"

  if occupied "$destination"; then
    if [ -f "$destination" ] && [ ! -L "$destination" ]; then
      say "preserved existing $label: $relative"
    else
      degrade "$relative (expected a regular file for $label)"
    fi
    return 0
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    say "would create $label: $relative"
    return 0
  fi

  if (set -o noclobber; cat "$source" > "$destination") 2>/dev/null; then
    say "created $label: $relative"
  elif occupied "$destination"; then
    degrade "$relative (appeared while creating $label)"
  else
    fatal "failed to create $label: $relative"
  fi
}

install_skill_if_absent() {
  local skill source relative destination
  skill="$1"
  source="$PAYLOAD/skills/$skill"
  relative="IB/skills/$skill"
  destination="$ROOT/$relative"

  if occupied "$destination"; then
    if [ -d "$destination" ] && [ ! -L "$destination" ] &&
       [ -f "$destination/SKILL.md" ] && [ ! -L "$destination/SKILL.md" ]; then
      if diff -qr "$source" "$destination" >/dev/null 2>&1; then
        say "already installed canonical skill tree: $relative"
        return 0
      fi
      degrade "$relative (existing canonical skill tree differs; preserving it)"
      return 0
    fi
    degrade "$relative (expected a real directory containing a real SKILL.md)"
    return 1
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    say "would create canonical skill tree: $relative"
    return 0
  fi

  mkdir "$destination" || fatal "failed to create skill directory: $relative"
  if cp -R "$source/." "$destination/"; then
    say "created canonical skill tree: $relative"
    return 0
  fi
  fatal "failed to copy canonical skill tree: $relative"
}

skill_is_usable() {
  local skill path
  skill="$1"
  path="$ROOT/IB/skills/$skill"
  if [ "$DRY_RUN" -eq 1 ] && ! occupied "$path"; then
    return 0
  fi
  [ -d "$path" ] && [ ! -L "$path" ] &&
    [ -f "$path/SKILL.md" ] && [ ! -L "$path/SKILL.md" ]
}

link_checked() {
  local relative target destination current
  relative="$1"
  target="$2"
  destination="$ROOT/$relative"

  if [ -L "$destination" ]; then
    current=$(readlink "$destination" 2>/dev/null || true)
    if [ "$current" = "$target" ]; then
      say "already linked: $relative -> $target"
      return 0
    fi
    degrade "$relative (existing symlink target is '$current', expected '$target')"
    return 1
  fi

  if [ -e "$destination" ]; then
    degrade "$relative (occupied; expected symlink to '$target')"
    return 1
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    say "would link: $relative -> $target"
    return 0
  fi

  if ln -s "$target" "$destination" 2>/dev/null; then
    say "linked: $relative -> $target"
    return 0
  fi

  if occupied "$destination"; then
    degrade "$relative (appeared while creating adapter)"
    return 1
  fi
  fatal "failed to create adapter: $relative"
}

setup_claude_skills() {
  local skill
  say ""
  say "Claude Code skills:"
  if ! ensure_dir ".claude/skills"; then
    say "manual action: expose IB/skills/* under .claude/skills/ without replacing existing entries"
    return
  fi
  for skill in "${SKILLS[@]}"; do
    if skill_is_usable "$skill"; then
      link_checked ".claude/skills/$skill" "../../IB/skills/$skill" || true
    else
      degrade ".claude/skills/$skill (canonical skill is not safely usable)"
    fi
  done
}

setup_agents_skills() {
  local skill
  say ""
  say "Codex/Pi shared skills:"
  # Report only KNOWN Tressoir adapters misplaced under the singular .agent/skills path.
  # Never create, move, remove, or traverse unrelated .agent/skills content.
  for skill in "${SKILLS[@]}"; do
    if occupied "$ROOT/.agent/skills/$skill"; then
      degrade ".agent/skills/$skill is a non-canonical Tressoir adapter (canonical path is .agents/skills/$skill); preserving it — migrate it manually"
    fi
  done
  if ! ensure_dir ".agents/skills"; then
    say "manual action: expose IB/skills/* under .agents/skills/ without replacing existing entries"
    return
  fi
  for skill in "${SKILLS[@]}"; do
    if skill_is_usable "$skill"; then
      link_checked ".agents/skills/$skill" "../../IB/skills/$skill" || true
    else
      degrade ".agents/skills/$skill (canonical skill is not safely usable)"
    fi
  done
}

# Classify an existing guidance file's managed "# Tressoir Guidance" section, so setup can
# safely upgrade only what it generated and never clobber user-authored or ambiguous content.
#   complete  = exactly the current generated section
#   legacy    = exactly a prior release's generated section (safe to upgrade in place)
#   absent    = no managed section and no unrelated TRESSOIR.md mention
#   ambiguous = edited/duplicated managed section, or an unrelated TRESSOIR.md mention
guidance_state() {
  local file canonical legacy count section
  file="$1"
  canonical="$2"
  legacy="$3"
  count=$(grep -c '^# Tressoir Guidance$' "$file" 2>/dev/null)
  count=${count:-0}
  if [ "$count" -eq 0 ]; then
    if grep -F 'TRESSOIR.md' "$file" >/dev/null 2>&1; then
      echo ambiguous
    else
      echo absent
    fi
    return
  fi
  if [ "$count" -gt 1 ]; then
    echo ambiguous
    return
  fi
  section=$(awk '/^# Tressoir Guidance$/{f=1} f{print}' "$file")
  if [ "$section" = "$(printf '# Tressoir Guidance\n\n%s' "$canonical")" ]; then
    echo complete
  elif [ "$section" = "$(printf '# Tressoir Guidance\n\n%s' "$legacy")" ]; then
    echo legacy
  else
    echo ambiguous
  fi
}

register_guidance_file() {
  local relative canonical legacy label destination state pre
  relative="$1"
  canonical="$2"
  legacy="$3"
  label="$4"
  destination="$ROOT/$relative"

  if [ -L "$destination" ]; then
    degrade "$relative (refusing to edit a symlink for $label)"
    return
  fi

  if [ -e "$destination" ]; then
    if [ ! -f "$destination" ]; then
      degrade "$relative (expected a regular file for $label)"
      return
    fi
    state=$(guidance_state "$destination" "$canonical" "$legacy")
    case "$state" in
      complete)
        say "already registered (current Tressoir guidance): $relative"
        return
        ;;
      legacy)
        if [ "$DRY_RUN" -eq 1 ]; then
          say "would upgrade root guidance: $relative"
          return
        fi
        pre=$(awk '/^# Tressoir Guidance$/{exit} {print}' "$destination")
        if [ -n "$pre" ]; then
          printf '%s\n\n# Tressoir Guidance\n\n%s\n' "$pre" "$canonical" > "$destination" ||
            fatal "failed to upgrade root guidance: $relative"
        else
          printf '# Tressoir Guidance\n\n%s\n' "$canonical" > "$destination" ||
            fatal "failed to upgrade root guidance: $relative"
        fi
        say "upgraded root guidance: $relative"
        return
        ;;
      ambiguous)
        degrade "$relative (existing guidance is edited, duplicated, or unrelated; preserving it)"
        say "manual action for $relative — add this section yourself:"
        say ""
        say "# Tressoir Guidance"
        say ""
        printf '%s\n' "$canonical"
        return
        ;;
      *)
        if [ "$DRY_RUN" -eq 1 ]; then
          say "would append root guidance: $relative"
          return
        fi
        printf '\n\n# Tressoir Guidance\n\n%s\n' "$canonical" >> "$destination" ||
          fatal "failed to append root guidance: $relative"
        say "appended root guidance: $relative"
        return
        ;;
    esac
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    say "would create root guidance file: $relative"
    return
  fi

  if (
    set -o noclobber
    printf '# Tressoir Guidance\n\n%s\n' "$canonical" > "$destination"
  ) 2>/dev/null; then
    say "created root guidance file: $relative"
  elif occupied "$destination"; then
    degrade "$relative (appeared while creating $label)"
  else
    fatal "failed to create root guidance file: $relative"
  fi
}

register_claude_settings() {
  # Rides the --register-guidance permission (same gate as editing CLAUDE.md).
  # Applies Tressoir's Claude Code defaults, preserving any other settings:
  #   env.CLAUDE_CODE_AUTO_COMPACT_WINDOW=400000 (Claude Code's 1M default is
  #   costly and unnecessary here) and autoMemoryEnabled=false (IB owns memory).
  local relative destination tmp writer had
  relative=".claude/settings.json"
  destination="$ROOT/$relative"

  if [ -L "$destination" ]; then
    degrade "$relative (refusing to edit a symlink for Claude settings)"
    return
  fi
  if [ -e "$destination" ] && [ ! -f "$destination" ]; then
    degrade "$relative (expected a regular file for Claude settings)"
    return
  fi

  if command -v jq >/dev/null 2>&1; then
    writer=jq
  elif command -v python3 >/dev/null 2>&1; then
    writer=python3
  else
    degrade "$relative (needs jq or python3; add manually: env.CLAUDE_CODE_AUTO_COMPACT_WINDOW=\"400000\", autoMemoryEnabled=false)"
    return
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    if [ -f "$destination" ]; then
      say "would update Claude settings: $relative"
    else
      say "would create Claude settings: $relative"
    fi
    return
  fi

  ensure_dir ".claude" || return

  # Use a securely created, private file in the destination directory. Never
  # claim or remove a predictable user-owned path. For updates, copy metadata
  # before truncating the temp file so a restrictive settings mode is retained.
  tmp=$(mktemp "$ROOT/.claude/.tressoir-settings.XXXXXX") ||
    fatal "failed to create a temporary Claude settings file"
  CLAUDE_SETTINGS_TMP="$tmp"
  had=0
  if [ -f "$destination" ]; then
    had=1
    cp -p "$destination" "$tmp" || {
      cleanup_claude_settings_tmp
      fatal "failed to preserve Claude settings metadata: $relative"
    }
  fi

  if [ "$writer" = jq ]; then
    if [ "$had" -eq 1 ]; then
      jq -S '.env.CLAUDE_CODE_AUTO_COMPACT_WINDOW = "400000" | .autoMemoryEnabled = false' \
        "$destination" > "$tmp" 2>/dev/null || {
        cleanup_claude_settings_tmp
        degrade "$relative (existing file is not valid JSON; preserving it)"
        return
      }
    else
      printf '{}\n' | jq -S '.env.CLAUDE_CODE_AUTO_COMPACT_WINDOW = "400000" | .autoMemoryEnabled = false' \
        > "$tmp" || {
          cleanup_claude_settings_tmp
          fatal "failed to create Claude settings: $relative"
        }
    fi
  else
    if ! CLAUDE_SETTINGS_SRC="$destination" CLAUDE_SETTINGS_DST="$tmp" python3 - <<'PY' 2>/dev/null
import json, os
src = os.environ["CLAUDE_SETTINGS_SRC"]
dst = os.environ["CLAUDE_SETTINGS_DST"]
data = {}
if os.path.isfile(src):
    with open(src) as handle:
        data = json.load(handle)
if not isinstance(data, dict):
    raise SystemExit(1)
env = data.get("env")
if not isinstance(env, dict):
    env = {}
env["CLAUDE_CODE_AUTO_COMPACT_WINDOW"] = "400000"
data["env"] = env
data["autoMemoryEnabled"] = False
with open(dst, "w") as handle:
    json.dump(data, handle, indent=2, sort_keys=True)
    handle.write("\n")
PY
    then
      cleanup_claude_settings_tmp
      degrade "$relative (existing file is not valid JSON; preserving it)"
      return
    fi
  fi

  if [ "$had" -eq 1 ] && cmp -s "$tmp" "$destination"; then
    cleanup_claude_settings_tmp
    say "already current (Claude settings): $relative"
    return
  fi
  mv "$tmp" "$destination" || {
    cleanup_claude_settings_tmp
    fatal "failed to write Claude settings: $relative"
  }
  CLAUDE_SETTINGS_TMP=""
  if [ "$had" -eq 1 ]; then
    say "updated Claude settings: $relative"
  else
    say "created Claude settings: $relative"
  fi
}

register_root_guidance() {
  [ "$REGISTER_GUIDANCE" -eq 1 ] || return

  local claude_canonical claude_legacy agents_canonical agents_legacy
  # Claude directly @-includes the agreement, current status, and durable decisions.
  claude_canonical=$'@IB/TRESSOIR.md\n@IB/STATE.md\n@IB/CANON/ROOT_CANON.md'
  claude_legacy=$'@IB/TRESSOIR.md'
  # Codex/Pi prompts directly name the same three live files.
  agents_canonical=$'Before substantial work, read and follow `IB/TRESSOIR.md`.\nRead current status and open decisions in `IB/STATE.md`.\nRead durable project decisions in `IB/CANON/ROOT_CANON.md`.'
  agents_legacy=$'Before beginning substantial work, read and follow `IB/TRESSOIR.md`.'

  say ""
  say "Root guidance:"
  if [ "$CLAUDE" -eq 1 ]; then
    register_guidance_file \
      "CLAUDE.md" \
      "$claude_canonical" \
      "$claude_legacy" \
      "Claude root guidance"
    register_claude_settings
  fi
  if [ "$CODEX" -eq 1 ]; then
    register_guidance_file \
      "AGENTS.md" \
      "$agents_canonical" \
      "$agents_legacy" \
      "Codex root guidance"
  fi
  if [ "$PI" -eq 1 ] && [ "$CODEX" -eq 0 ]; then
    if ensure_dir ".pi"; then
      register_guidance_file \
        ".pi/APPEND_SYSTEM.md" \
        "$agents_canonical" \
        "$agents_legacy" \
        "Pi project guidance"
    else
      say "manual action: reference IB/TRESSOIR.md, IB/STATE.md, and IB/CANON/ROOT_CANON.md from your Pi project prompt"
    fi
  fi
}

inspect_installed_extension() {
  local output line prefix legacy_prefix
  INSTALLED_EXTENSION_VERSION=""
  INSTALLED_LEGACY_EXTENSION_VERSION=""
  output=$("$VSCODE_RESOLVED" --list-extensions --show-versions 2>/dev/null) || return 1
  prefix="${EXTENSION_ID}@"
  legacy_prefix="${LEGACY_EXTENSION_ID}@"
  while IFS= read -r line; do
    case "$line" in
      "$prefix"*)
        INSTALLED_EXTENSION_VERSION=${line#"$prefix"}
        ;;
      "$legacy_prefix"*)
        INSTALLED_LEGACY_EXTENSION_VERSION=${line#"$legacy_prefix"}
        ;;
    esac
  done <<EOF
$output
EOF
  return 0
}

is_semver_triplet() {
  local value major minor patch extra
  value="$1"
  case "$value" in
    ""|.*|*.|*..*|*[!0-9.]*)
      return 1
      ;;
  esac
  IFS=. read -r major minor patch extra <<EOF
$value
EOF
  [ -n "$major" ] && [ -n "$minor" ] && [ -n "$patch" ] && [ -z "$extra" ]
}

semver_compare() {
  # Prints -1, 0, or 1 for $1 compared with $2. Inputs are validated triplets.
  local left right l1 l2 l3 lextra r1 r2 r3 rextra
  left="$1"
  right="$2"
  IFS=. read -r l1 l2 l3 lextra <<EOF
$left
EOF
  IFS=. read -r r1 r2 r3 rextra <<EOF
$right
EOF

  if [ "$l1" -lt "$r1" ]; then printf '%s\n' -1; return; fi
  if [ "$l1" -gt "$r1" ]; then printf '%s\n' 1; return; fi
  if [ "$l2" -lt "$r2" ]; then printf '%s\n' -1; return; fi
  if [ "$l2" -gt "$r2" ]; then printf '%s\n' 1; return; fi
  if [ "$l3" -lt "$r3" ]; then printf '%s\n' -1; return; fi
  if [ "$l3" -gt "$r3" ]; then printf '%s\n' 1; return; fi
  printf '%s\n' 0
}

install_vscode_extension() {
  local comparison previous_version

  say ""
  say "VS Code extension:"
  if [ "$NO_VSCODE" -eq 1 ]; then
    say "skipped by request: $EXTENSION_ID@$EXTENSION_VERSION"
    return
  fi

  if [ -n "$INSTALLED_LEGACY_EXTENSION_VERSION" ]; then
    degrade "$LEGACY_EXTENSION_ID@$INSTALLED_LEGACY_EXTENSION_VERSION is installed and may conflict with $EXTENSION_ID when enabled (both own the Tressoir artifact editor view types)"
    say "setup cannot determine enabled state; skipping the standalone extension conservatively"
    say "manual action: uninstall $LEGACY_EXTENSION_ID, reload VS Code, then rerun setup"
    say "skipped: $EXTENSION_ID@$EXTENSION_VERSION"
    return
  fi

  if [ "$INSTALLED_EXTENSION_VERSION" = "$EXTENSION_VERSION" ]; then
    say "already installed: $EXTENSION_ID@$EXTENSION_VERSION"
    return
  fi

  if [ -n "$INSTALLED_EXTENSION_VERSION" ]; then
    if ! is_semver_triplet "$INSTALLED_EXTENSION_VERSION"; then
      degrade "$EXTENSION_ID@$INSTALLED_EXTENSION_VERSION (unrecognized installed version; not replacing)"
      return
    fi
    comparison=$(semver_compare "$INSTALLED_EXTENSION_VERSION" "$EXTENSION_VERSION")
    if [ "$comparison" -gt 0 ]; then
      degrade "$EXTENSION_ID@$INSTALLED_EXTENSION_VERSION (newer than supplied $EXTENSION_VERSION; not downgrading)"
      return
    fi
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    say "would install: $EXTENSION_ID@$EXTENSION_VERSION via $VSCODE_RESOLVED"
    return
  fi

  previous_version="$INSTALLED_EXTENSION_VERSION"
  "$VSCODE_RESOLVED" --install-extension "$VSIX_PATH" --force ||
    fatal "VS Code extension installation failed after project setup"

  inspect_installed_extension ||
    fatal "could not verify VS Code extension after installation"
  [ "$INSTALLED_EXTENSION_VERSION" = "$EXTENSION_VERSION" ] ||
    fatal "VS Code reported '$INSTALLED_EXTENSION_VERSION' after installing $EXTENSION_VERSION"
  say "installed: $EXTENSION_ID@$EXTENSION_VERSION"
  if [ -n "$previous_version" ]; then
    say "manual action: reload the VS Code window or close and reopen affected artifact tabs"
  fi
}

print_instruction_handoff() {
  say ""
  say "Root guidance:"
  say "  canonical file: IB/TRESSOIR.md"
  if [ "$REGISTER_GUIDANCE" -eq 1 ]; then
    say "  opt-in root registration was requested"
    if [ "$CLAUDE" -eq 1 ]; then
      say "  Claude Code target: CLAUDE.md"
      say "  Claude Code defaults: .claude/settings.json (compact window + auto-memory off)"
    fi
    if [ "$CODEX" -eq 1 ]; then
      say "  Codex target: AGENTS.md"
    fi
    if [ "$PI" -eq 1 ] && [ "$CODEX" -eq 1 ]; then
      say "  Pi target: AGENTS.md (shared with Codex)"
    elif [ "$PI" -eq 1 ]; then
      say "  Pi target: .pi/APPEND_SYSTEM.md"
    fi
    say "  Edited, duplicated, or unrelated guidance was preserved unchanged."
  else
    if [ "$CLAUDE" -eq 1 ]; then
      say "  Claude Code option: add @IB/TRESSOIR.md, @IB/STATE.md, and @IB/CANON/ROOT_CANON.md to your chosen CLAUDE.md"
      say "  Claude Code option: set .claude/settings.json env.CLAUDE_CODE_AUTO_COMPACT_WINDOW=400000 and autoMemoryEnabled=false"
    fi
    if [ "$CODEX" -eq 1 ]; then
      say "  Codex option: tell agents to read IB/TRESSOIR.md, IB/STATE.md, and IB/CANON/ROOT_CANON.md in your chosen AGENTS.md"
    fi
    if [ "$PI" -eq 1 ]; then
      say "  Pi option: reference IB/TRESSOIR.md, IB/STATE.md, and IB/CANON/ROOT_CANON.md from your chosen context file, or launch with:"
      say "             pi --append-system-prompt ./IB/TRESSOIR.md"
    fi
  fi
  if [ "$PI" -eq 1 ]; then
    say "  Pi project skills require project trust and Pi 0.80.6-compatible .agents/skills discovery."
  fi
  say "  Setup never edits nested Claude, override, rules, global, or Pi SYSTEM.md files."
}

# ---------------------------------------------------------------------------

if [ "$#" -eq 0 ]; then
  usage >&2
  exit 1
fi

COMMAND="$1"
shift
case "$COMMAND" in
  setup) ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    fatal "unsupported command: $COMMAND"
    ;;
esac

while [ "$#" -gt 0 ]; do
  case "$1" in
    --claude)
      CLAUDE=1
      shift
      ;;
    --codex)
      CODEX=1
      shift
      ;;
    --pi)
      PI=1
      shift
      ;;
    --register-guidance)
      REGISTER_GUIDANCE=1
      shift
      ;;
    --root)
      [ "$#" -ge 2 ] || fatal "--root requires a path"
      ROOT_INPUT="$2"
      shift 2
      ;;
    --vsix)
      [ "$#" -ge 2 ] || fatal "--vsix requires a path"
      VSIX_INPUT="$2"
      shift 2
      ;;
    --vscode-bin)
      [ "$#" -ge 2 ] || fatal "--vscode-bin requires a path or command name"
      VSCODE_BIN="$2"
      shift 2
      ;;
    --no-vscode)
      NO_VSCODE=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fatal "unknown option: $1"
      ;;
  esac
done

[ "$NO_VSCODE" -eq 0 ] || [ -z "$VSIX_INPUT" ] ||
  fatal "--vsix and --no-vscode cannot be used together"
[ "$REGISTER_GUIDANCE" -eq 0 ] || [ "$CLAUDE" -eq 1 ] ||
  [ "$CODEX" -eq 1 ] || [ "$PI" -eq 1 ] ||
  fatal "--register-guidance requires at least one selected harness"
[ "$NO_VSCODE" -eq 0 ] || [ "$CLAUDE" -eq 1 ] ||
  [ "$CODEX" -eq 1 ] || [ "$PI" -eq 1 ] ||
  fatal "setup requires VS Code installation or at least one harness"

if [ -z "$ROOT_INPUT" ]; then
  ROOT_INPUT=$PWD
fi
[ -d "$ROOT_INPUT" ] || fatal "project root does not exist: $ROOT_INPUT"
ROOT=$(CDPATH= cd -- "$ROOT_INPUT" 2>/dev/null && pwd -P) ||
  fatal "cannot resolve project root: $ROOT_INPUT"

SELF_DIR=$(resolve_self_dir)
PAYLOAD=$(CDPATH= cd -- "$SELF_DIR/../share/tressoir-external" 2>/dev/null && pwd -P) ||
  fatal "cannot locate adjacent share/tressoir-external payload"

say "Tressoir External setup"
say "  project root: $ROOT"
say "  payload: $PAYLOAD"
if [ "$DRY_RUN" -eq 1 ]; then
  say "  mode: dry-run"
fi

verify_payload
preflight_project

say ""
say "Canonical IB:"
ensure_dir "IB/ARTIFACTS" || fatal "canonical IB/ARTIFACTS path is unsafe"
ensure_dir "IB/TMP" || fatal "canonical IB/TMP path is unsafe"
ensure_dir "IB/CANON" || fatal "canonical IB/CANON path is unsafe"
ensure_dir "IB/CANON/CANON_ARTIFACTS" ||
  fatal "canonical IB/CANON/CANON_ARTIFACTS path is unsafe"
ensure_dir "IB/skills" || fatal "canonical IB/skills path is unsafe"

copy_file_if_absent "$PAYLOAD/seeds/TASK.md" "IB/TASK.md" "user task seed"
copy_file_if_absent "$PAYLOAD/seeds/STATE.md" "IB/STATE.md" "project state seed"
copy_file_if_absent "$PAYLOAD/seeds/ROOT_CANON.md" "IB/CANON/ROOT_CANON.md" "root canon seed"
copy_file_if_absent \
  "$PAYLOAD/seeds/CANON_ARTIFACTS_README.md" \
  "IB/CANON/CANON_ARTIFACTS/README.md" \
  "canon artifacts guide"
copy_file_if_absent "$PAYLOAD/instructions/TRESSOIR.md" "IB/TRESSOIR.md" "canonical instructions"
copy_file_if_absent "$PAYLOAD/seeds/IB.gitignore" "IB/.gitignore" "IB ignore rules"

for skill in "${SKILLS[@]}"; do
  install_skill_if_absent "$skill" || true
done

if [ "$CLAUDE" -eq 1 ]; then
  setup_claude_skills
fi
if [ "$CODEX" -eq 1 ] || [ "$PI" -eq 1 ]; then
  setup_agents_skills
fi

register_root_guidance
install_vscode_extension
print_instruction_handoff

say ""
if [ "$DEGRADED" -eq 1 ]; then
  say "Setup completed safely with preserved collisions or manual adapter work."
  exit 2
fi
if [ "$DRY_RUN" -eq 1 ]; then
  say "Dry-run complete; no project or VS Code changes were made."
else
  say "Setup complete."
fi
exit 0
